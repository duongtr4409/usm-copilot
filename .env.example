POSTGRES_USER=usm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=usm_db

# JWT / security
JWT_SECRET=replace_with_secure_random_value

# Frontend
VITE_API_BASE=http://localhost:8080
# Postgres
POSTGRES_USER=usm
POSTGRES_PASSWORD=change_me
POSTGRES_DB=usm

# JWT secret used by backend (replace in production)
JWT_SECRET=change-this-in-production

# Frontend: base URL for API (Vite uses VITE_ prefix)
VITE_API_BASE=http://localhost:8080/api
# Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────
POSTGRES_DB=usm
POSTGRES_USER=usm_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full JDBC URL (used by Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# ─────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
APP_JWT_SECRET=CHANGE_ME_generate_a_512bit_random_hex_string
APP_JWT_ACCESS_TOKEN_EXPIRY_SECONDS=900
APP_JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# ─────────────────────────────────────────────────────────
# SPRING APPLICATION
# ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=development
SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=USM
VITE_APP_ENV=development

# ─────────────────────────────────────────────────────────
# CLOUD / DEPLOYMENT (Azure)
# ─────────────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_REGISTRY=
AZURE_SUBSCRIPTION_ID=

# ─────────────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────────────
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
